<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="tlib_Theme.NativesApplications" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/tlib_purple_500</item>
        <item name="colorPrimaryVariant">@color/tlib_purple_700</item>
        <item name="colorOnPrimary">@color/tlib_white</item>
        <item name="colorSecondary">@color/tlib_teal_200</item>
        <item name="colorSecondaryVariant">@color/tlib_teal_700</item>
        <item name="colorOnSecondary">@color/tlib_black</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>

    <style name="tlib_AdTheme" >
        <item name="android:background">@color/tlib_black</item>
        <item name="android:windowBackground">@color/tlib_black</item>
        <item name="android:windowExitAnimation">@null</item>
        <item name="android:windowEnterAnimation">@null</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>


</resources>